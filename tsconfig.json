{
    "compilerOptions": {
        "paths": {
            "src/*": ["./src/*"]
        },
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "importHelpers": true,
        "types": ["node", "jest"],
        "lib": ["dom", "dom.Iterable", "scripthost", "ES5", "ES6", "ES7", "ES2021"],
        "jsx": "react",
        "jsxFactory": "h",
        "noEmit": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["build", "coverage", "node_modules"],
    "files": ["node_modules/jest-expect-message/types/index.d.ts", "eslint.config.mjs"]
}
